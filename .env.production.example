NODE_ENV=production
APP_NAME=QuickRest
APP_URL=https://quickrest.example.com
PORT=3000

POSTGRES_DB=quickrest
POSTGRES_USER=quickrest
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgres://quickrest:replace-with-a-long-random-postgres-password@postgres:5432/quickrest

REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@redis:6379

SESSION_SECRET=replace-with-at-least-32-random-bytes-base64-or-hex
API_KEY_PEPPER=replace-with-at-least-32-random-bytes-base64-or-hex
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
DEFAULT_CREDIT_COST=1

STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=https://quickrest.example.com/billing/success
STRIPE_CANCEL_URL=https://quickrest.example.com/credits

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-temporary-admin-password
ADMIN_RECOVERY_PIN=1234567890
